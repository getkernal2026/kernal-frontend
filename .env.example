# ── Supabase (frontend — anon key only, safe to expose) ──────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Backend API (Railway) ─────────────────────────────────────────────────────
VITE_API_URL=https://your-backend.up.railway.app

# ── Sentry (frontend error tracking) ─────────────────────────────────────────
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# true  → loads full mock/seed dataset (for sales demos and walkthroughs)
# false → app starts empty (production / real pilot customers)
VITE_DEMO_MODE=false
